# VOT Core Configs
PORT=8080
ENV=development
LOG_LEVEL=info
# Comma-separated Origin values the web client (web/) is served from.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# AES-256 key (base64) encrypting each user's stored broker credentials at
# rest. Generate your own — do not reuse this value: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=changeme_generate_your_own_32_byte_base64_key

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=vot
POSTGRES_PASSWORD=vot_dev_password
POSTGRES_DB=vot_tradings
POSTGRES_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# The three broker sections below are OPTIONAL and only used by the
# POST /api/v1/broker-credentials/import-env convenience endpoint, which
# copies these into a logged-in user's own encrypted credential rows for
# local testing. They are not read anywhere else — each real user connects
# their own broker credentials via the app (Profile page), not via .env.

# Alpaca Sandbox (US Equities)
ALPACA_API_KEY_ID=your_alpaca_key_id
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# OANDA Sandbox (Forex)
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_ACCESS_TOKEN=your_oanda_access_token
OANDA_BASE_URL=https://api-fxpractice.oanda.com

# Questrade Sandbox (Canadian Equities)
QUESTRADE_REFRESH_TOKEN=your_questrade_refresh_token
QUESTRADE_AUTH_URL=https://login.questrade.com/oauth2/token

# Deep Learning Engine
DL_ENGINE_URL=http://localhost:5000
DL_ENGINE_TIMEOUT_MS=2000
